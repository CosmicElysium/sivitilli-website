---
import type { Project } from "../data/content";
import ProjectImage from "./ProjectImage.astro";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="project-card" id={project.slug}>
  <div class="project-visual">
    {
      project.image ? (
        <ProjectImage src={project.image} alt={project.imageAlt} />
      ) : (
        <div class="project-placeholder" aria-hidden="true">
          <span>{project.mark}</span>
        </div>
      )
    }
  </div>

  <div class="project-content">
    <div class="project-meta">
      <span>{project.period}</span>
      <span>{project.organisation}</span>
    </div>

    <h3>{project.title}</h3>
    <p class="project-summary">{project.summary}</p>

    <ul class="tag-list" aria-label={`${project.title} topics`}>
      {project.tags.map((tag) => <li>{tag}</li>)}
    </ul>

    <details>
      <summary>Read project overview</summary>
      <div class="details-copy">
        {project.details.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </details>

    {
      ["laser-alignment-telescope", "digital-planetarium-learning"].includes(
        project.slug,
      ) && (
        <a
          class="text-link"
          href={`/projects/${project.slug}/`}
          aria-label={`Read the full ${project.title} project page`}
        >
          View full project
          <span aria-hidden="true">→</span>
        </a>
      )
    }

    {
      project.links.length > 0 && (
        <div class="project-links">
          {project.links.map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer">
              <span class="link-type">{link.type ?? "Link"}</span>
              <strong>{link.label}</strong>
              {link.description && <span>{link.description}</span>}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>
