---
import "../styles/global.css";
import { socialLinks } from "../data/content";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Alexander Sivitilli",
  description = "Immersive scientific visualisation, machine learning, astronomy and spatial computing.",
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalURL = new URL(currentPath, "https://sivitil.li");
const currentYear = new Date().getFullYear();

const navItems = [
  { label: "Home", href: "/" },
  { label: "Projects", href: "/projects/" },
  { label: "Publications", href: "/publications/" },
];

const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07111f" />

    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <title>{title}</title>
  </head>

  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>

    <header class="site-header">
      <nav class="nav shell" aria-label="Primary navigation">
        <a class="brand" href="/" aria-label="Alexander Sivitilli home">
          <span class="brand-mark" aria-hidden="true">AS</span>
          <span class="brand-name">Alexander Sivitilli</span>
        </a>

        <div class="nav-links">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            ))
          }
          <a href="/cv/Alexander-Sivitilli-CV.pdf">CV</a>
          <a href="/#contact">Contact</a>
        </div>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer shell">
      <p>© {currentYear} Alexander Sivitilli</p>

      <div class="footer-links" aria-label="Professional profiles">
        {
          socialLinks.map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer">
              {link.label}
            </a>
          ))
        }
      </div>
    </footer>
  </body>
</html>
