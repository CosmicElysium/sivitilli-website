---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectImage from "../../components/ProjectImage.astro";
import { projects } from "../../data/content";

const project = projects.find(
  (item) => item.slug === "laser-alignment-telescope",
);

if (!project) {
  throw new Error(
    'Project "laser-alignment-telescope" was not found in src/data/content.ts.',
  );
}

const statusLabel = project.status === "past" ? "Completed" : "Current";

// Add approved images under public/images/projects/laser-alignment/,
// then set the corresponding paths below. Empty paths are not rendered.
const images = {
  hero: {
    src: "/images/projects/laser-alignment/argos-lasers.webp",
    alt: "The ARGOS laser guide stars propagating above the Large Binocular Telescope at night",
    caption:
      "The six ARGOS Rayleigh laser guide stars at the Large Binocular Telescope.",
  },
  instrument: {
    src: "/images/projects/laser-alignment/laser-alignment-telescope.webp",
    alt: "The Laser Alignment Telescope mounted on the Large Binocular Telescope structure",
    caption:
      "The Laser Alignment Telescope after installation on the Large Binocular Telescope.",
  },
  algorithm: {
    src: "/images/projects/laser-alignment/alignment-detection.webp",
    alt: "A Laser Alignment Telescope image annotated with detected laser beams and fitted endpoints",
    caption:
      "An example of the image-analysis workflow used to identify the beam geometry and endpoint constellation.",
  },
  interface: {
    src: "/images/projects/laser-alignment/argos-alignment-interface.webp",
    alt: "The ARGOS control interface showing a Laser Alignment Telescope frame and alignment controls",
    caption:
      "The alignment workflow as integrated into the ARGOS control interface.",
  },
};

const galleryImages = [
  images.instrument,
  images.algorithm,
  images.interface,
].filter((image) => image.src);

// Add a public thesis URL when one is available, for example:
// "/documents/sivitilli-laser-alignment-thesis.pdf"
const thesisHref = "/documents/sivitilli_masters_thesis.pdf";

const benchmarkRows = [
  {
    method: "Sideways threshold",
    medianTime: "2.4 s",
    successRate: "72%",
  },
  {
    method: "Skeleton",
    medianTime: "7.2 s",
    successRate: "96%",
  },
  {
    method: "Gaussian subtraction",
    medianTime: "4.1 s",
    successRate: "92%",
    selected: true,
  },
];
---

<BaseLayout
  title="Laser Alignment Telescope and Smart Laser Alignment · Alexander Sivitilli"
  description="Design, construction and commissioning of a telescope and computer-vision workflow for aligning the ARGOS laser guide stars at the Large Binocular Telescope."
>
  <article class="project-page">
    <nav class="project-breadcrumb shell" aria-label="Breadcrumb">
      <a href="/projects/">Projects</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">Laser alignment</span>
    </nav>

    <header
      class:list={[
        "project-detail-hero",
        "shell",
        !images.hero.src && "project-detail-hero--without-media",
      ]}
    >
      <div class="project-detail-intro">
        <p class="eyebrow">Astronomical instrumentation · Completed project</p>
        <h1>Laser Alignment Telescope and Smart Laser Alignment</h1>
        <p class="project-deck">
          A purpose-built telescope and computer-vision workflow developed to
          locate and coarsely align the six ARGOS Rayleigh laser guide stars at
          the Large Binocular Telescope.
        </p>

        <div class="button-row">
          {
            project.links.map((link) => (
              <a
                class:list={[
                  "button",
                  link.type === "Source code" && "primary",
                ]}
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                {link.label}
              </a>
            ))
          }
          {
            thesisHref && (
              <a
                class="button"
                href={thesisHref}
                target="_blank"
                rel="noopener noreferrer"
              >
                Read the thesis
              </a>
            )
          }
        </div>
      </div>

      {
        images.hero.src && (
          <figure class="project-hero-media">
            <ProjectImage
              src={images.hero.src}
              alt={images.hero.alt}
              width="1600"
              height="1067"
              loading="eager"
              fetchpriority="high"
            />
            <figcaption>{images.hero.caption}</figcaption>
          </figure>
        )
      }

      <dl class="project-facts">
        <div>
          <dt>Status</dt>
          <dd>{statusLabel}</dd>
        </div>
        <div>
          <dt>Dates</dt>
          <dd>{project.period}</dd>
        </div>
        <div>
          <dt>Institution</dt>
          <dd>{project.organisation}</dd>
        </div>
        <div>
          <dt>Context</dt>
          <dd>ARGOS · Large Binocular Telescope</dd>
        </div>
        <div>
          <dt>Role</dt>
          <dd>Research assistant and master's researcher</dd>
        </div>
      </dl>

      <ul class="project-tags" aria-label="Project topics">
        {project.tags.map((tag) => <li>{tag}</li>)}
      </ul>
    </header>

    <div class="project-body shell">
      <section class="project-detail-section" aria-labelledby="overview-title">
        <div class="section-label">
          <p class="eyebrow">Overview</p>
          <h2 id="overview-title">From manual acquisition to a repeatable workflow.</h2>
        </div>

        <div class="project-prose">
          <p class="lead">
            The Advanced Rayleigh guided Ground layer adaptive Optics System
            (ARGOS) uses three laser guide stars for each of the Large Binocular
            Telescope's two mirrors. These artificial reference stars allow the
            system to measure atmospheric distortion across a wide field and
            improve the observations delivered to its scientific instruments.
          </p>

          <p>
            Before ARGOS can make those measurements, the light returned from
            each laser at an altitude of 12 kilometres must fall close enough to
            its wavefront sensor for the acquisition system to see it. Telescope
            flexure and maintenance could move the beams outside that capture
            range, leaving the team to recover them through a time-consuming
            manual search.
          </p>

          <p>
            The project addressed that operational gap as a connected
            instrument-and-software problem. The Laser Alignment Telescope (LAT)
            supplied a wide-field image of the launched beams. The Smart Laser
            Alignment (SLA) software then detected their geometry, estimated the
            required correction and passed that correction into the ARGOS
            control system.
          </p>
        </div>
      </section>

      <section class="project-detail-section" aria-labelledby="role-title">
        <div class="section-label">
          <p class="eyebrow">My role</p>
          <h2 id="role-title">Work across optics, control software and image analysis.</h2>
        </div>

        <div class="project-prose">
          <p>
            I was responsible for the end-to-end development of the LAT and its
            alignment workflow as part of my master's research and subsequent
            work with the ARGOS group at the Max Planck Institute for Astronomy.
            The work moved from requirements and prototyping through installation
            and commissioning at the Large Binocular Telescope Observatory.
          </p>

          <ul class="scope-list">
            <li>
              Selected, assembled and tested the telescope, camera, electronic
              focus system, protective housing and dust shutter.
            </li>
            <li>
              Developed the networked control software for image acquisition,
              camera settings, focus control and shutter operation.
            </li>
            <li>
              Designed and implemented the Python image-analysis and alignment
              workflow.
            </li>
            <li>
              Calibrated the telescope-to-laser coordinate transformation and
              modelled relative flexure across telescope elevation.
            </li>
            <li>
              Supported installation, on-sky testing, commissioning and
              integration with the wider ARGOS software architecture.
            </li>
          </ul>
        </div>
      </section>

      <section class="project-detail-section" aria-labelledby="system-title">
        <div class="section-label">
          <p class="eyebrow">System design</p>
          <h2 id="system-title">One workflow, three connected layers.</h2>
        </div>

        <div class="system-grid">
          <article class="system-card">
            <p class="system-number" aria-hidden="true">01</p>
            <h3>Laser Alignment Telescope</h3>
            <p>
              A 152 mm refractor and 2048 × 2048-pixel camera combined a
              roughly one-degree field with a pixel scale of about 1.7
              arcseconds per pixel. The instrument was mounted in a protective,
              adjustable housing on the telescope structure.
            </p>
          </article>

          <article class="system-card">
            <p class="system-number" aria-hidden="true">02</p>
            <h3>Control software</h3>
            <p>
              A client-server interface controlled the camera, motorised focus
              and dust shutter over the observatory network. The same interface
              supported ARGOS integration and more general use of the LAT by
              Large Binocular Telescope staff.
            </p>
          </article>

          <article class="system-card">
            <p class="system-number" aria-hidden="true">03</p>
            <h3>Smart Laser Alignment</h3>
            <p>
              The Python workflow located the projected laser beams, reduced
              them to a stable endpoint constellation and converted an image
              offset into movement commands for the final laser-launch mirrors.
            </p>
          </article>
        </div>
      </section>

      <section class="project-detail-section" aria-labelledby="approach-title">
        <div class="section-label">
          <p class="eyebrow">Approach</p>
          <h2 id="approach-title">Turning an image into a mirror correction.</h2>
        </div>

        <div class="project-prose">
          <ol class="process-list">
            <li>
              <div>
                <h3>Acquire and prepare a LAT frame</h3>
                <p>
                  The LAT captured a wide-field image containing one or both
                  three-beam laser constellations. Image processing reduced
                  background structure and prepared row profiles for detection.
                </p>
              </div>
            </li>
            <li>
              <div>
                <h3>Find and organise the laser peaks</h3>
                <p>
                  Repeated Gaussian fitting and subtraction identified bright
                  peaks across image rows. A slope test associated those peaks
                  with the expected near-parallel laser tracks and rejected
                  inconsistent detections.
                </p>
              </div>
            </li>
            <li>
              <div>
                <h3>Fit the beams and locate their endpoints</h3>
                <p>
                  Lines were fitted through the accepted points. Integrated flux
                  profiles along those lines were used to estimate where each
                  beam faded into the background, producing three endpoint
                  coordinates.
                </p>
              </div>
            </li>
            <li>
              <div>
                <h3>Compare the constellation with a calibrated target</h3>
                <p>
                  A circle fitted to the three endpoints provided a stable
                  constellation centre. Its displacement from an
                  elevation-corrected target represented the coarse alignment
                  error.
                </p>
              </div>
            </li>
            <li>
              <div>
                <h3>Transform the offset into telescope commands</h3>
                <p>
                  Calibration matrices converted the pixel displacement into the
                  two movement axes of the primary launch mirror for the relevant
                  side of the telescope. ARGOS could then apply the correction
                  and hand over to its finer acquisition system.
                </p>
              </div>
            </li>
          </ol>
        </div>
      </section>

      <section class="project-detail-section" aria-labelledby="testing-title">
        <div class="section-label">
          <p class="eyebrow">Development testing</p>
          <h2 id="testing-title">Balancing speed with reliable detection.</h2>
        </div>

        <div class="project-prose">
          <p>
            Three row-scanning strategies were compared on a development image
            set. The skeleton method found the complete laser pattern most
            often, but it was also the slowest. Gaussian subtraction was selected
            as the better compromise between speed and robustness for the
            integrated workflow.
          </p>

          <div class="table-wrap" tabindex="0" aria-label="Scrollable benchmark table">
            <table>
              <caption>
                Development benchmark reported in the 2016 thesis; these figures
                describe the test image set rather than present-day operational
                performance.
              </caption>
              <thead>
                <tr>
                  <th scope="col">Detection method</th>
                  <th scope="col">Median time per image</th>
                  <th scope="col">Complete-detection rate</th>
                  <th scope="col">Decision</th>
                </tr>
              </thead>
              <tbody>
                {
                  benchmarkRows.map((row) => (
                    <tr>
                      <th scope="row">{row.method}</th>
                      <td>{row.medianTime}</td>
                      <td>{row.successRate}</td>
                      <td>{row.selected ? "Selected" : "Not selected"}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </div>
      </section>

      {
        galleryImages.length > 0 && (
          <section
            class="project-detail-section"
            aria-labelledby="media-title"
          >
            <div class="section-label">
              <p class="eyebrow">Project media</p>
              <h2 id="media-title">Instrument, analysis and integration.</h2>
            </div>

            <div class="project-gallery">
              {galleryImages.map((image) => (
                <figure>
                  <ProjectImage
                    src={image.src}
                    alt={image.alt}
                    width="1400"
                    height="933"
                    loading="lazy"
                  />
                  <figcaption>{image.caption}</figcaption>
                </figure>
              ))}
            </div>
          </section>
        )
      }

      <section class="project-detail-section" aria-labelledby="outcomes-title">
        <div class="section-label">
          <p class="eyebrow">Outcomes</p>
          <h2 id="outcomes-title">A commissioned system with documented trade-offs.</h2>
        </div>

        <div class="outcomes-grid">
          <article>
            <h3>Instrument and integration</h3>
            <p>
              The LAT was built, installed and aligned on the Large Binocular
              Telescope, replacing the ageing Mount Alignment Telescope. Its
              control software and the SLA workflow were integrated into the
              ARGOS software environment, including visual controls and a manual
              fallback.
            </p>
          </article>

          <article>
            <h3>Commissioning benefit</h3>
            <p>
              At the time of completion, we estimated three hours of accumulated
              alignment time saved across ten days of laser use during two
              commissioning runs. This is a project-specific estimate, not a
              claim about later or current observatory operations.
            </p>
          </article>

          <article>
            <h3>Open implementation</h3>
            <p>
              The image-analysis work was released as open-source scientific
              software, preserving the detection and alignment methods for
              inspection, reuse and further development.
            </p>
          </article>

          <article>
            <h3>Engineering lessons</h3>
            <p>
              Commissioning exposed practical limits in the focus mechanism,
              optical collimation, aberrations and relative flexure. Rather than
              hiding those issues, the thesis documented them alongside repairs,
              compensation models and proposed hardware improvements.
            </p>
          </article>
        </div>
      </section>

      <section class="project-detail-section" aria-labelledby="limits-title">
        <div class="section-label">
          <p class="eyebrow">Limitations and future work</p>
          <h2 id="limits-title">What remained beyond the original project.</h2>
        </div>

        <div class="project-prose">
          <p>
            Relative flexure between the LAT and the main telescope exceeded the
            30-arcsecond capture budget across the ARGOS operating elevation
            range, so the target position required an elevation-dependent
            correction. A friction-drive problem in the original focus mechanism
            also required repair and motivated a more robust rack-and-pinion
            replacement.
          </p>

          <p>
            The project explored, but did not complete, an atmospheric
            height-analysis method based on beam geometry and Rayleigh-scattered
            light. That extension was intended to make endpoint interpretation
            more robust in cloudy conditions and was explicitly left as future
            work.
          </p>
        </div>
      </section>

      <section class="project-detail-section" aria-labelledby="collaboration-title">
        <div class="section-label">
          <p class="eyebrow">Collaboration</p>
          <h2 id="collaboration-title">Developed within the ARGOS team.</h2>
        </div>

        <div class="project-prose">
          <p>
            The project was carried out at the Max Planck Institute for
            Astronomy under the supervision of Klaus Meisenheimer and with
            Wolfgang Gässler as project mentor. Software, calibration,
            integration and commissioning support came from colleagues across
            the ARGOS collaboration and the Large Binocular Telescope
            Observatory, including José Luis Borelli, Martin Kulas, Lorenzo
            Busoni, Marco Bonaglia, Sebastian Rabien and the wider observatory
            team.
          </p>
        </div>
      </section>

      <section class="project-resources" aria-labelledby="resources-title">
        <div>
          <p class="eyebrow">Resources</p>
          <h2 id="resources-title">Code and project background.</h2>
        </div>

        <div class="resource-list">
          {
            project.links.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="resource-type">{link.type}</span>
                <strong>{link.label}</strong>
                {link.description && <span>{link.description}</span>}
              </a>
            ))
          }
          {
            thesisHref && (
              <a
                href={thesisHref}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="resource-type">Master's thesis</span>
                <strong>
                  Design and Implementation of a Laser Alignment Telescope for
                  ARGOS on the Large Binocular Telescope
                </strong>
                <span>
                  The complete technical account of the instrument, software,
                  commissioning and remaining engineering work.
                </span>
              </a>
            )
          }
        </div>
      </section>

      <nav class="project-footer-nav" aria-label="Project navigation">
        <a href="/projects/">
          <span aria-hidden="true">←</span>
          Back to all projects
        </a>
      </nav>
    </div>
  </article>
</BaseLayout>

<style>
  .project-page {
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }

  .project-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding-top: clamp(1.5rem, 4vw, 3rem);
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  .project-breadcrumb a {
    text-underline-offset: 0.22em;
  }

  .project-detail-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
    padding-block: clamp(3rem, 8vw, 7.5rem);
  }

  .project-detail-hero--without-media .project-detail-intro {
    grid-column: 1 / -1;
    max-width: 72rem;
  }

  .project-detail-hero--without-media .project-facts,
  .project-detail-hero--without-media .project-tags {
    grid-column: 1 / -1;
  }

  .project-detail-intro h1 {
    max-width: 14ch;
    margin-top: 0.8rem;
    font-size: clamp(3.25rem, 8.5vw, 7.5rem);
    letter-spacing: -0.065em;
    line-height: 0.91;
  }

  .project-deck {
    max-width: 48rem;
    margin: 1.6rem 0 0;
    color: var(--text-soft);
    font-size: clamp(1.15rem, 2.2vw, 1.5rem);
    line-height: 1.55;
  }

  .project-detail-intro .button-row {
    margin-top: 2rem;
  }

  .project-hero-media {
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 1.2rem;
    background: var(--surface);
  }

  .project-hero-media :global(.project-image) {
    width: 100%;
    aspect-ratio: 4 / 3;
  }

  .project-hero-media figcaption,
  .project-gallery figcaption {
    padding: 0.85rem 1rem 1rem;
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  .project-facts {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    margin: 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .project-facts div {
    min-width: 0;
    padding: 1.1rem 1.1rem 1.15rem 0;
  }

  .project-facts div + div {
    padding-left: 1.1rem;
    border-left: 1px solid var(--line);
  }

  .project-facts dt {
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 750;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .project-facts dd {
    margin: 0.3rem 0 0;
    color: var(--text);
    font-size: 0.94rem;
    line-height: 1.45;
  }

  .project-tags {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: -1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .project-tags li {
    padding: 0.42rem 0.72rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(134, 184, 255, 0.06);
    color: var(--text-soft);
    font-size: 0.82rem;
  }

  .project-body {
    display: grid;
  }

  .project-detail-section {
    display: grid;
    grid-template-columns: minmax(190px, 0.42fr) minmax(0, 1.58fr);
    gap: clamp(2rem, 7vw, 7rem);
    padding-block: clamp(3.5rem, 8vw, 7rem);
    border-top: 1px solid var(--line);
  }

  .section-label h2 {
    max-width: 15ch;
    margin-top: 0.75rem;
    font-size: clamp(1.7rem, 3.2vw, 2.8rem);
    letter-spacing: -0.04em;
    line-height: 1.08;
  }

  .project-prose {
    max-width: 52rem;
  }

  .project-prose p {
    margin: 0;
    color: var(--text-soft);
    font-size: 1.04rem;
  }

  .project-prose p + p {
    margin-top: 1.35rem;
  }

  .project-prose .lead {
    color: var(--text);
    font-size: clamp(1.18rem, 2.3vw, 1.55rem);
    line-height: 1.55;
  }

  .scope-list {
    display: grid;
    gap: 0.8rem;
    margin: 2rem 0 0;
    padding: 0;
    list-style: none;
  }

  .scope-list li {
    position: relative;
    padding: 1rem 1rem 1rem 2.6rem;
    border: 1px solid var(--line);
    border-radius: 0.8rem;
    background: var(--surface);
    color: var(--text-soft);
  }

  .scope-list li::before {
    position: absolute;
    top: 1rem;
    left: 1rem;
    content: "✓";
    color: var(--accent);
    font-weight: 800;
  }

  .system-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .system-card {
    min-height: 22rem;
    padding: clamp(1.35rem, 3vw, 2rem);
    border: 1px solid var(--line);
    border-radius: 1rem;
    background: var(--surface);
  }

  .system-number {
    margin: 0 0 3rem;
    color: var(--accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
      monospace;
    font-size: 0.8rem;
  }

  .system-card h3 {
    font-size: 1.35rem;
    line-height: 1.2;
  }

  .system-card p:last-child {
    margin: 1rem 0 0;
    color: var(--text-soft);
  }

  .process-list {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    counter-reset: process;
    list-style: none;
  }

  .process-list li {
    position: relative;
    display: grid;
    grid-template-columns: 3.5rem minmax(0, 1fr);
    gap: 1rem;
    padding: 0 0 2.25rem;
    counter-increment: process;
  }

  .process-list li::before {
    width: 2.8rem;
    height: 2.8rem;
    display: grid;
    place-items: center;
    border: 1px solid var(--line-strong);
    border-radius: 50%;
    content: counter(process, decimal-leading-zero);
    color: var(--accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
      monospace;
    font-size: 0.75rem;
  }

  .process-list li:not(:last-child)::after {
    position: absolute;
    top: 3rem;
    bottom: 0.2rem;
    left: 1.37rem;
    width: 1px;
    content: "";
    background: var(--line);
  }

  .process-list h3 {
    margin-top: 0.15rem;
    font-size: 1.22rem;
  }

  .process-list p {
    margin-top: 0.55rem;
  }

  .table-wrap {
    max-width: 100%;
    margin-top: 2rem;
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 0.9rem;
